# Copy to .env and edit once — loaded automatically on npm run dev / npm start
PORT=3001
MASTER_KEY=change-me-to-a-long-random-string
DATA_DIR=./data
# MONGODB_URI=mongodb://localhost:27017/claudepress
# FRESHPRESS_DB_NAME=claudepress
# (legacy DB name claudepress preserved by default — set FRESHPRESS_DB_NAME=freshpress_acme for new installs)
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=anthropic/claude-sonnet-4
APP_URL=http://localhost:3001
# HOSTED=1
# KEY_ENCRYPTION_SECRET=  # optional; defaults to MASTER_KEY for BYOK vault encryption
